  {
    "doctype": "MM Email Template",
    "template_name": "Customer - Business Confirmation",
    "email_type": "Booking Confirmation",
    "recipient_type": "Customer",
    "service_type": "Business",
    "is_active": 1,
    "language": "en",
    "priority": 10,
    "subject": "Your Business Meeting Confirmation",
    "email_body": "<p style=\"margin:0 0 4px;font-size:15px;color:#374151;\">Hi {{ company }},</p><p style=\"margin:0 0 16px;font-size:15px;color:#374151;\">Attn: {{ customer_name }},</p><p style=\"margin:0 0 16px;font-size:15px;color:#374151;\">Thank you for the great conversation we just had. As agreed, I am sending you the details regarding your scheduled meeting.</p><table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" style=\"margin:20px 0;\"><tr><td style=\"background-color:#fffbeb;border-left:4px solid #e8a914;border-radius:0 6px 6px 0;padding:20px 24px;\"><p style=\"margin:0 0 4px;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:#92400e;\">Your Scheduled Meeting</p><table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" style=\"margin-top:10px;\"><tr><td style=\"padding:6px 0;color:#6b7280;font-size:14px;width:100px;\">Consultant</td><td style=\"padding:6px 0;color:#1f2937;font-size:14px;font-weight:600;\">{{ provider }}</td></tr><tr><td style=\"padding:6px 0;color:#6b7280;font-size:14px;\">Date</td><td style=\"padding:6px 0;color:#1f2937;font-size:14px;font-weight:600;\">{{ event_date }}</td></tr><tr><td style=\"padding:6px 0;color:#6b7280;font-size:14px;\">Time</td><td style=\"padding:6px 0;color:#1f2937;font-size:14px;font-weight:600;\">{{ event_time }}</td></tr></table></td></tr></table><p style=\"margin:0 0 16px;font-size:15px;color:#374151;\">I have also attached our business brochure so you can learn more about us.</p><table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" style=\"margin:16px 0;background-color:#f9fafb;border-radius:6px;padding:0;\"><tr><td style=\"padding:16px 20px;\"><p style=\"margin:0 0 8px;font-size:13px;font-weight:600;color:#1f2937;\">About BestSecurity</p><p style=\"margin:0 0 6px;font-size:13px;color:#6b7280;line-height:1.5;\">BestSecurity ApS is one of Denmark's leading IT companies, with offices at Christians Brygge 28, 1559 Copenhagen V and Anelystparken 31, 8381 Tilst.</p><table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" style=\"margin-top:8px;\"><tr><td width=\"50%\" style=\"font-size:12px;color:#6b7280;padding:2px 0;\"><strong style=\"color:#374151;\">Phone Hours:</strong> Mon\u2013Thu 09:00\u201317:00, Fri 09:00\u201316:30</td></tr><tr><td style=\"font-size:12px;color:#6b7280;padding:2px 0;\"><strong style=\"color:#374151;\">Meeting Hours:</strong> Mon\u2013Thu 07:00\u201317:00, Fri 07:00\u201315:00</td></tr></table></td></tr></table><p style=\"margin:0 0 16px;font-size:15px;color:#374151;\">The security check is expected to take 30\u201345 minutes. During the session, our IT technician will cover IT security, backup, and GDPR.</p><p style=\"margin:0 0 8px;font-size:14px;font-weight:600;color:#1f2937;\">Before our call, please install our remote support software:</p><table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" style=\"margin:16px 0 24px;\"><tr><td style=\"background-color:#e8a914;border-radius:6px;\"><a href=\"{{ remote_support_link }}\" style=\"display:inline-block;padding:12px 28px;color:#ffffff;font-size:14px;font-weight:600;text-decoration:none;letter-spacing:0.3px;\">Install Remote Support Software</a></td></tr></table><p style=\"margin:0 0 16px;font-size:15px;color:#374151;\">We look forward to assisting you.</p><p style=\"margin:24px 0 4px;font-size:15px;color:#374151;\">Best regards,</p><p style=\"margin:0;font-size:15px;font-weight:600;color:#1f2937;\">{{ booker }}</p><p style=\"margin:2px 0 0;font-size:13px;color:#9ca3af;\">Business Consultant, BestSecurity</p>",
    "include_remote_support_link": 1,
    "remote_support_url": "https://rmmeu-bestsecurity.screenconnect.com/",
    "include_brochure": 1
  },
