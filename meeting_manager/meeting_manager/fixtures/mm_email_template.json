e=\"margin:16px 0;\"><tr><td style=\"padding-right:20px;\"><a href=\"{{ reschedule_link }}\" style=\"color:#e8a914;font-size:13px;font-weight:500;text-decoration:none;\">Reschedule Meeting</a></td><td><a href=\"{{ cancel_link }}\" style=\"color:#9ca3af;font-size:13px;font-weight:500;text-decoration:none;\">Cancel Meeting</a></td></tr></table><p style=\"margin:24px 0 4px;font-size:15px;color:#374151;\">Best regards,</p><p style=\"margin:0;font-size:15px;font-weight:600;color:#1f2937;\">{{ booker }}</p><p style=\"margin:2px 0 0;font-size:13px;color:#9ca3af;\">BestSecurity</p>",
