 4px;font-size:14px;color:#374151;\">{{ customer_email }}</p>{% if customer_phone %}<p style=\"margin:0;font-size:14px;color:#374151;\">{{ customer_phone }}</p>{% endif %}</td></tr></table><p style=\"margin:0 0 16px;font-size:13px;color:#6b7280;\">Booked by: {{ booker }}</p><table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" style=\"margin:16px 0;\"><tr><td style=\"background-color:#3b82f6;border-radius:6px;\"><a href=\"{{ booking_url }}\" style=\"display:inline-block;padding:12px 28px;color:#ffffff;font-size:14px;font-weight:600;text-decoration:none;letter-spacing:0.3px;\">View Booking Details</a></td></tr></table>",
